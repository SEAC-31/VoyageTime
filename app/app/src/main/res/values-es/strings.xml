    <!-- About Us -->
    <string name="about_title">Sobre VoyageTime</string>
    <string name="about_version">Versión 1.0.0</string>
    <string name="about_what_title">¿Qué es VoyageTime?</string>
    <string name="about_what_body">VoyageTime es tu compañero de viaje personal. Planifica viajes, organiza itinerarios, registra ideas y guarda todos tus recuerdos de viaje en un solo lugar con una experiencia limpia y visual.</string>
    <string name="about_features_title">Características principales</string>
    <string name="about_feature_trips">Planifica y gestiona tus viajes fácilmente</string>
    <string name="about_feature_gallery">Guarda una galería de tus recuerdos de viaje</string>
    <string name="about_feature_itinerary">Organiza itinerarios detallados día a día</string>
    <string name="about_feature_notifications">Recibe recordatorios de tus próximos viajes</string>
    <string name="about_feature_offline">Accede a información importante sin conexión</string>
    <string name="about_mission_title">Nuestra misión</string>
    <string name="about_mission_body">Creamos VoyageTime para que la planificación de viajes sea inspiradora, sencilla y visualmente agradable. Cada viaje merece un lugar donde los tiempos, las ideas, los recuerdos y la planificación se unan de forma hermosa.</string>
    <string name="about_tech_title">Información técnica</string>
    <string name="about_tech_kotlin">Desarrollado con Kotlin y Jetpack Compose</string>
    <string name="about_tech_storage">Organización local de viajes y datos editables</string>
    <string name="about_tech_nav">Navegación estructurada y diseño escalable de pantallas</string>
    <string name="about_footer_tagline">Diseñado para viajeros que buscan claridad, estilo y control.</string>
    <string name="about_team_title">👥  Nuestro equipo</string>
    <string name="about_team_body">VoyageTime está creado con pasión por un pequeño equipo de entusiastas de los viajes y desarrolladores. Creemos que viajar cambia vidas y queremos que planificarlo sea tan agradable como el propio viaje.</string>
    <string name="about_contact_title">📬  Contacto</string>
    <string name="about_contact_body">¿Tienes comentarios o has encontrado un error? Nos encantaría saberlo.</string>
    <string name="about_contact_email">contact@voyagetime.app</string>
    <string name="about_footer">Hecho con ❤️ para viajeros\n© 2025 VoyageTime</string>
    <string name="about_back">Volver atrás</string>

